DATABASE_URL=sqlite:///./cricviz.db
CRICKETDATA_KEY=          # optional — get free key at cricketdata.org (100 hits/day)
ADMIN_KEY=change_me_in_production

HF_API_TOKEN="your_huggingface_token_here"
HF_PRIMARY_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_MAX_NEW_TOKENS=400
HF_TEMPERATURE=0.7
HF_TIMEOUT_SECONDS=35

# Celery Configuration
# CELERY_BROKER_URL="redis://localhost:6379/0"
# CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# Auth Configuration
# SECRET_KEY="generate_a_secure_random_string_here"

# Commentary Enrichment (post-ingestion)
# COMMENTARY_ENRICH_DAYS=7
# COMMENTARY_DAILY_LIMIT=90
