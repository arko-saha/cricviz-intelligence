HF_API_TOKEN="your_huggingface_token_here"
HF_PRIMARY_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_MAX_NEW_TOKENS=400
HF_TEMPERATURE=0.7
HF_TIMEOUT_SECONDS=35
CRICAPI_KEY="your_cricapi_key_here"

# Database Configuration
# By default, SQLite is used (sqlite:///cricviz.db)
# To use PostgreSQL, provide a valid connection string:
# DATABASE_URL="postgresql://user:password@localhost:5432/cricviz"

# Celery Configuration
# CELERY_BROKER_URL="redis://localhost:6379/0"
# CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# Auth Configuration
# SECRET_KEY="generate_a_secure_random_string_here"
